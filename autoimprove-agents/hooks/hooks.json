{
  "description": "Modular CLAUDE.md architecture, NotebookLM knowledge base, and self-improvement loop for agents",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash '${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh'",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash '${CLAUDE_PLUGIN_ROOT}/hooks/stop-remind.sh'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
